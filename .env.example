DATABASE_URL="postgresql://user:password@localhost:5432/jlpt_n2_trainer"
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
OPENAI_API_KEY="sk-..." # Optional for AI features

# OAuth - Social Login (Google & Facebook)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Password reset & email verification (6-digit codes). In development, if unset, reset links / codes are printed to the server console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="JLPT Trainer <noreply@yourdomain.com>"
# SMTP_SECURE="true"  # use for port 465

# Feedback / bug reports: comma-separated admin inboxes (uses same SMTP_* as above)
FEEDBACK_NOTIFY_EMAIL="admin@yourdomain.com"

# Floating handbook link (bottom-right FAB). Must be NEXT_PUBLIC_* for the browser.
NEXT_PUBLIC_JAPANESE_HANDBOOK_URL="https://example.com/your-handbook"
